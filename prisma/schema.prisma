generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  inGameName    String?
  rank          GuildRank @default(CABIN_BOY)
  isPublic      Boolean  @default(true)  // opt-in roster visibility
  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt
  supabaseId    String   @unique         // links to Supabase Auth user

  // Relations
  userShips     UserShip[]
  userResources UserResource[]
  userConsumables UserConsumable[]
  userCurrencies  UserCurrency[]

  @@map("users")
}

enum GuildRank {
  FOUNDER
  ADMIRAL
  COMMODORE
  OFFICER
  MIDSHIPMAN
  SAILOR
  CABIN_BOY
}

// ============================================================
// CATALOG: SHIPS
// ============================================================

model Ship {
  id          String    @id @default(uuid())
  name        String    @unique
  rate        Int       // 1-7
  shipClass   String    // Fast, Combat, Transport, Heavy, Siege, Imperial
  faction     String?
  hp          Int?
  speed       Float?
  cargoHold   Int?
  cannonSlots Int?
  crewCapacity Int?
  description String?

  // Relations
  userShips   UserShip[]

  @@map("ships")
}

// ============================================================
// CATALOG: WEAPONS
// ============================================================

model Weapon {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String   // Cannon, Long Cannon, Carronade, Mortar, Special
  tier        String?  // Basic, Advanced, Pirate
  damage      Int?
  range       Float?
  reloadTime  Float?
  description String?

  // Relations
  userShipWeapons UserShipWeapon[]

  @@map("weapons")
}

// ============================================================
// CATALOG: UPGRADES
// ============================================================

model Upgrade {
  id          String   @id @default(uuid())
  name        String   @unique
  slot        String?  // e.g., Sails, Hull, Deck, etc.
  description String?
  effect      String?

  // Relations
  userShipUpgrades UserShipUpgrade[]

  @@map("upgrades")
}

// ============================================================
// CATALOG: AMMO TYPES
// ============================================================

model AmmoType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  effect      String?

  // Relations
  userShipAmmo UserShipAmmo[]

  @@map("ammo_types")
}

// ============================================================
// CATALOG: CONSUMABLES
// ============================================================

model Consumable {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String?  // Repair, Buff, Tactical
  description String?
  effect      String?

  // Relations
  userConsumables UserConsumable[]

  @@map("consumables")
}

// ============================================================
// CATALOG: RESOURCES
// ============================================================

model Resource {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String   // Raw, Processed
  description String?

  // Relations
  userResources UserResource[]

  @@map("resources")
}

// ============================================================
// CATALOG: CURRENCIES
// ============================================================

model Currency {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  // Relations
  userCurrencies UserCurrency[]

  @@map("currencies")
}

// ============================================================
// CATALOG: CREW TYPES
// ============================================================

model CrewType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  // Relations
  userShipCrew UserShipCrew[]

  @@map("crew_types")
}

// ============================================================
// USER INVENTORY: SHIPS (a user's owned ships)
// ============================================================

model UserShip {
  id          String   @id @default(uuid())
  userId      String
  shipId      String
  nickname    String?  // player's custom name for their ship
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ship        Ship     @relation(fields: [shipId], references: [id])

  // Ship loadout
  weapons     UserShipWeapon[]
  upgrades    UserShipUpgrade[]
  ammo        UserShipAmmo[]
  crew        UserShipCrew[]

  @@map("user_ships")
}

// Weapons equipped on a user's ship
model UserShipWeapon {
  id          String   @id @default(uuid())
  userShipId  String
  weaponId    String
  quantity    Int      @default(1)

  userShip    UserShip @relation(fields: [userShipId], references: [id], onDelete: Cascade)
  weapon      Weapon   @relation(fields: [weaponId], references: [id])

  @@map("user_ship_weapons")
}

// Upgrades installed on a user's ship
model UserShipUpgrade {
  id          String   @id @default(uuid())
  userShipId  String
  upgradeId   String

  userShip    UserShip @relation(fields: [userShipId], references: [id], onDelete: Cascade)
  upgrade     Upgrade  @relation(fields: [upgradeId], references: [id])

  @@map("user_ship_upgrades")
}

// Ammo loaded on a user's ship
model UserShipAmmo {
  id          String   @id @default(uuid())
  userShipId  String
  ammoTypeId  String
  quantity    Int      @default(0)

  userShip    UserShip @relation(fields: [userShipId], references: [id], onDelete: Cascade)
  ammoType    AmmoType @relation(fields: [ammoTypeId], references: [id])

  @@map("user_ship_ammo")
}

// Crew assigned to a user's ship
model UserShipCrew {
  id          String   @id @default(uuid())
  userShipId  String
  crewTypeId  String
  quantity    Int      @default(0)

  userShip    UserShip @relation(fields: [userShipId], references: [id], onDelete: Cascade)
  crewType    CrewType @relation(fields: [crewTypeId], references: [id])

  @@map("user_ship_crew")
}

// ============================================================
// USER INVENTORY: RESOURCES
// ============================================================

model UserResource {
  id          String   @id @default(uuid())
  userId      String
  resourceId  String
  quantity    Int      @default(0)
  isPublic    Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource    Resource @relation(fields: [resourceId], references: [id])

  @@unique([userId, resourceId])
  @@map("user_resources")
}

// ============================================================
// USER INVENTORY: CONSUMABLES
// ============================================================

model UserConsumable {
  id            String     @id @default(uuid())
  userId        String
  consumableId  String
  quantity      Int        @default(0)
  isPublic      Boolean    @default(true)
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumable    Consumable @relation(fields: [consumableId], references: [id])

  @@unique([userId, consumableId])
  @@map("user_consumables")
}

// ============================================================
// USER INVENTORY: CURRENCIES
// ============================================================

model UserCurrency {
  id          String   @id @default(uuid())
  userId      String
  currencyId  String
  amount      Float    @default(0)
  isPublic    Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency    Currency @relation(fields: [currencyId], references: [id])

  @@unique([userId, currencyId])
  @@map("user_currencies")
}
