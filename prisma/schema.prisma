generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  inGameName    String?
  rank          GuildRank @default(CABIN_BOY)
  isPublic      Boolean  @default(true)
  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt
  supabaseId    String   @unique

  userShips       UserShip[]
  userResources   UserResource[]
  userConsumables UserConsumable[]
  userCurrencies  UserCurrency[]

  @@map("users")
}

enum GuildRank {
  ADMIN
  FOUNDER
  ADMIRAL
  COMMODORE
  OFFICER
  MIDSHIPMAN
  SAILOR
  CABIN_BOY
}

// ============================================================
// CATALOG: SHIPS
// ============================================================

model Ship {
  id               String   @id @default(uuid())
  name             String   @unique
  rate             Int      // 1-7
  shipClass        String   // e.g. "Ship of the Line", "Frigate", "Cutter"
  role             String?  // Battle, Transport, Fast-moving, Siege
  faction          String?
  hp               Int?
  speed            Float?
  maneuverability  Int?
  broadsideArmor   Float?
  cargoHold        Int?
  crewCapacity     Int?
  displacement     String?
  integrity        Int?
  description      String?

  // Weapon system
  weaponClass        String?  // "Light", "Medium", "Heavy"
  sternSlots         Int      @default(0)
  broadsideSlots     Int      @default(0)  // per side (port = starboard = this number)
  bowSlots           Int      @default(0)
  swivelGuns         Int      @default(0)
  mortarSlots        Int      @default(0)
  mortarMaxCaliber   Int?
  specialWeaponSlots Int      @default(0)

  userShips UserShip[]

  @@map("ships")
}

// ============================================================
// CATALOG: WEAPONS
// ============================================================

model Weapon {
  id                   String   @id @default(uuid())
  name                 String   @unique
  weightClass          String   // "Light", "Medium", "Heavy", "Mortar", "Special"
  type                 String   // "Cannon", "Long Cannon", "Carronade", "Bombard", "Mortar", "Special"
  penetration          Float?
  penetrationMulti     String?  // e.g. "x2", "x3", "x8" for multi-shot weapons
  loading              Float?   // seconds
  range                Int?
  rangeMin             Int?     // mortars have min range
  maxAngle             Int?
  accuracySpread       Float?
  damage               Int?     // mortars use this instead of penetration
  splashRadius         Int?     // mortars only
  reduction            Float?   // mortars only
  preparation          Float?   // some mortars only
  firingTime           Int?     // special weapons (Alchemical Fire)
  damageUnit           String?  // "per sec" for Alchemical Fire
  caliber              Int?     // mortar caliber in inches
  placementRestriction String?  // "Only for the bow or stern", "For special ships"
  isPremium            Boolean  @default(false)
  description          String?

  loadoutWeapons LoadoutWeapon[]

  @@map("weapons")
}

// ============================================================
// CATALOG: UPGRADES
// ============================================================

model Upgrade {
  id          String   @id @default(uuid())
  name        String   @unique
  slot        String?
  description String?
  effect      String?
  effects     Json?    // Array of {stat, value} objects for stat modifications

  loadoutUpgrades LoadoutUpgrade[]

  @@map("upgrades")
}

// ============================================================
// CATALOG: AMMO TYPES
// ============================================================

model AmmoType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  effect      String?

  loadoutAmmo LoadoutAmmo[]

  @@map("ammo_types")
}

// ============================================================
// CATALOG: CONSUMABLES
// ============================================================

model Consumable {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String?
  description String?
  effect      String?

  userConsumables UserConsumable[]

  @@map("consumables")
}

// ============================================================
// CATALOG: RESOURCES
// ============================================================

model Resource {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String
  description String?

  userResources UserResource[]

  @@map("resources")
}

// ============================================================
// CATALOG: CURRENCIES
// ============================================================

model Currency {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  userCurrencies UserCurrency[]

  @@map("currencies")
}

// ============================================================
// CATALOG: CREW TYPES
// ============================================================

model CrewType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  faction     String?  // "Adventurers", "Pirates", "Sailors", "Military", or null for basic crew

  loadoutCrew LoadoutCrew[]

  @@map("crew_types")
}

// ============================================================
// USER INVENTORY: SHIPS + LOADOUTS
// ============================================================

model UserShip {
  id        String   @id @default(uuid())
  userId    String
  shipId    String
  nickname  String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ship     Ship      @relation(fields: [shipId], references: [id])
  loadouts Loadout[]

  @@map("user_ships")
}

model Loadout {
  id         String   @id @default(uuid())
  userShipId String
  name       String   @default("Loadout 1")
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userShip UserShip        @relation(fields: [userShipId], references: [id], onDelete: Cascade)
  weapons  LoadoutWeapon[]
  upgrades LoadoutUpgrade[]
  ammo     LoadoutAmmo[]
  crew     LoadoutCrew[]

  @@map("loadouts")
}

model LoadoutWeapon {
  id        String @id @default(uuid())
  loadoutId String
  weaponId  String
  position  String // "stern", "port", "starboard", "bow", "mortar", "special"
  quantity  Int    @default(1)

  loadout Loadout @relation(fields: [loadoutId], references: [id], onDelete: Cascade)
  weapon  Weapon  @relation(fields: [weaponId], references: [id])

  @@map("loadout_weapons")
}

model LoadoutUpgrade {
  id        String @id @default(uuid())
  loadoutId String
  upgradeId String

  loadout Loadout @relation(fields: [loadoutId], references: [id], onDelete: Cascade)
  upgrade Upgrade @relation(fields: [upgradeId], references: [id])

  @@map("loadout_upgrades")
}

model LoadoutAmmo {
  id         String @id @default(uuid())
  loadoutId  String
  ammoTypeId String
  quantity   Int    @default(0)

  loadout  Loadout  @relation(fields: [loadoutId], references: [id], onDelete: Cascade)
  ammoType AmmoType @relation(fields: [ammoTypeId], references: [id])

  @@map("loadout_ammo")
}

model LoadoutCrew {
  id         String @id @default(uuid())
  loadoutId  String
  crewTypeId String
  quantity   Int    @default(0)

  loadout  Loadout  @relation(fields: [loadoutId], references: [id], onDelete: Cascade)
  crewType CrewType @relation(fields: [crewTypeId], references: [id])

  @@map("loadout_crew")
}

// ============================================================
// USER INVENTORY: RESOURCES
// ============================================================

model UserResource {
  id         String   @id @default(uuid())
  userId     String
  resourceId String
  quantity   Int      @default(0)
  isPublic   Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([userId, resourceId])
  @@map("user_resources")
}

// ============================================================
// USER INVENTORY: CONSUMABLES
// ============================================================

model UserConsumable {
  id           String     @id @default(uuid())
  userId       String
  consumableId String
  quantity     Int        @default(0)
  isPublic     Boolean    @default(true)
  updatedAt    DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumable Consumable @relation(fields: [consumableId], references: [id])

  @@unique([userId, consumableId])
  @@map("user_consumables")
}

// ============================================================
// USER INVENTORY: CURRENCIES
// ============================================================

model UserCurrency {
  id         String   @id @default(uuid())
  userId     String
  currencyId String
  amount     Float    @default(0)
  isPublic   Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyId], references: [id])

  @@unique([userId, currencyId])
  @@map("user_currencies")
}
