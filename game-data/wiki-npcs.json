  "spawnMechanics": {
    "regionSpawning": {
      "description": "Each region generates NPCs based on level and area factor",
      "areaFactor": "region.AreaFactor × 73/85 squared × 1.07",
      "traderCount": 5,
      "ferrymanCount": "~4-8 based on area factor (×2 for last region, ×3)",
      "pirateRegularCount": "5-10 (doubled in low-level regions ≤ 2)",
      "pirateReinforcedCount": "~8-12 based on 1.4 × (9 - level/3) × areaFactor",
      "pirateFleetCount": "~3-6 based on 3 × areaFactor",
      "fr2Count": "Same formulas but not doubled for low-level regions",
      "fanaticCount": "5 per region (near strongholds only) + reinforced variants",
      "headhunterCount": 6,
      "seaElfCount": "3 per region (level ≥ 2, event only)"
    },
    "bossSpawning": {
      "legendary2l": "Spawn per-region based on SpawnRegions array. 5-min respawn interval.",
      "legendary3l": "Only in highest-level region. 720-min (12h) respawn. Spawn in LegendBossZone.",
      "generation": "FleetsPerRegion × FleetSize total ships active"
    },
    "portSpawning": {
      "description": "Each port with AllowCapture generates patrol NPCs",
      "patrols": "3 per faction (cycling through nations + None)",
      "flagship": "1 per port — ship selected by region level (ID 12/14/35/62)",
      "invasionShips": "3 per port"
    },
    "npcStats": {
      "description": "Regular NPC stats generated procedurally from ship base stats",
      "shipSelection": "CanBeUsedForNpc ships matching region level ± rank tolerance (±2, or ±0 for port patrols)",
      "armorCalc": "baseArmor + lerp(minUpgrade - 0.3, maxUpgrade, random). Elite ships get -0.5 armor.",
      "speedCalc": "baseSpeed - (1-regionFactor) + regionBonus + destroyerBonus×1.5 + lerp(minUpgrade, maxUpgrade, random)",
      "hpCalc": "baseHP × (0.7 + 0.3×regionFactor + 0.2×destroyerBonus - heavyShipPenalty) + lerp(minUpgrade, maxUpgrade, random). Region 0: ×0.85, Region 1: ×0.9",
      "damageCalc": "cannonPenetration × portCount × 0.9 × (0.5 + 0.5×regionFactor + regionBonus). Region 0: ×0.85",
      "reloadCalc": "cannonReloadTime × (1 - 0.2×destroyerBonus). Minimum 5500ms.",
      "randomUpgrades": "0-2 random upgrades from: ReduceFireDamage, SailProtection, ReduceNoseDamage, CollisionDamage, MoreFireDamage, CannonBallSpeed"
    }
  },
  "npcCrewCount": {
    "formula": "floor(((min(40, HP/50) or 40+(excess/2)) + 3 + hash_bonus) × typeMultiplier × 4)",
    "typeMultipliers": {
