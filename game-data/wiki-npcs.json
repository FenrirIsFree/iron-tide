      "allOthers": 0.92
    },
    "inputHP": "max(500, actualHP)",
    "cap": "At 40 crew base, excess is halved: 40 + (raw - 40) / 2",
    "description": "Higher HP ships get more crew but with diminishing returns above ~2000 HP. Legendary2l bosses get 13% fewer crew proportionally."
  },
