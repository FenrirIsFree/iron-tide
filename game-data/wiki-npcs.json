  "rewardSystem": {
    "description": "How NPC rewards are calculated based on ship stats and NPC type",
    "basicRewardFormula": {
      "xpCalculation": "XP from HP^0.97 \u00d7 1.19, modified by speed/armor/damage. Final XP = gold reward \u00d7 XP rate \u00d7 type modifier \u00d7 0.9",
      "goldCalculation": "Base gold (75, or 150 for traders) + location multiplier \u00d7 (combat + damage bonus) \u00d7 game speed \u00d7 0.79",
      "combatBonus": "Based on HP \u00d7 0.69 + 330, speed, and armor",
      "damageBonus": "Based on DPS \u00d7 (300 + HP) \u00f7 75, scaled down",
      "cannonBalls": "15 + Water Hazard level \u00d7 6 for regular NPCs, 45 + Water Hazard level \u00d7 15 for legendary"
    },
    "locationMultipliers": {
      "worldMap": "Standard world map multiplier",
      "openSea": "Open sea multiplier (outside normal boundaries)",
      "bonusMap": "Bonus/passing map multiplier",
      "empireInvasion": "Invasion NPCs get 70% of normal location rewards"
    },
    "sinkingVsBoarding": {
      "sinking": "Get resource drops + gold + cannonballs + chance for powerup items",
      "boarding": "Can capture ship (if not Empire/Patrol), get crew, different loot table"
    },
