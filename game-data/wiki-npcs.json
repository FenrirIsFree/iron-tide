  "rewardSystem": {
    "description": "How NPC rewards are calculated based on ship stats and NPC type",
    "basicRewardFormula": {
      "xpCalculation": "Base from HP^0.97 × 1.19, modified by speed, armor, and damage output. XP = goldReward × BasicXpInGold × typeModifier × 0.9",
      "goldCalculation": "baseGold(75 or 150 for traders) + locationMultiplier × (combatBonus + damageBonus) × GameSpeed × 0.88 × 0.9",
      "combatBonus": "ComputeBasicBonus(HP × 0.69 + 330, speed, armor)",
      "damageBonus": "(DPS × (300 + HP) / 75) × 0.85 × 2 / 10",
      "cannonBalls": "15 + hazardLevel × 6 for regular, 45 + hazardLevel × 15 for legendary"
    },
    "locationMultipliers": {
      "worldMap": "Gameplay.WorldMapMultiplier",
      "seamlessSea": "Gameplay.OutsideSeamMultiplier",
      "bonusMap": "Gameplay.DefaultBonusMapMultiplier",
      "empireInvasion": "locationMultiplier × 0.7"
    },
    "sinkingVsBoarding": {
      "sinking": "Get resource drops + gold + cannonballs + chance for powerup items",
      "boarding": "Can capture ship (if not Empire/Patrol), get crew, different loot table"
    },
    "lootByType": {
      "pirates": {
        "regular": "70% gold, 30% provisions (region resources). Pirate Treasure Maps (1 in 30 chance). In north regions, additional trade goods.",
        "reinforced": "Pirate Tokens (res 72) in hazard zones (HP/100 rounded), otherwise Wood (res 1) at 33% gold value. Bonus resource packs (res 24) at 80% gold value.",
        "fleet_fr1": "Cannon drops from ship's allowed cannon types",
        "fleet_fr2_order": "2 random picks from [res 39, 9, 10, 22, 1] at 50% gold value each"
      },
      "traders": {
        "regular": "Region-specific trade goods from nearby ports. Merchant Supply Maps (1 in 20 chance). Gold portion: 33% in safe zones, 25% in hazard zones.",
        "ferryman": "3 different trade resources (RandomCut 3), richer loot per resource",
        "tradingRouteBonus": "If trader is on a trading route, its resource gets extra weight"
      },
      "empire": {
        "regular": "Imperial Stamps (Escudo, res 15) — amount based on HP, scaled by location",
        "invasion": "Reduced rewards (0.7× location multiplier). Escudo drops.",
        "legendary2l": "Escudo (HP/3200), rare trade goods (1500 gold value), 50% chance of specialty ammo (res 24). Gold remainder.",
        "legendary3l": "Large Escudo drops (4-6 for fleet 3, 8-10 for fleet 2, 24-28 for solo). Copper (res 11) 17-25, Voodoo Skulls (res 38) ×3, Iron (res 4). Creates loot by dropping chests."
      },
      "fanatics": "Same as regular pirates (provisions + gold)",
